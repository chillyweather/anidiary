<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= year %> <%= season.charAt(0).toUpperCase() + season.slice(1) %> - anidiary</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="nav">
    <a class="nav__logo" href="/">anidiary</a>
    <div class="nav__season-picker">
      <a href="/season/<%= adjacentSeasons.prevYear %>/<%= adjacentSeasons.prevSeason %>">
        ← <%= adjacentSeasons.prevSeason.charAt(0).toUpperCase() + adjacentSeasons.prevSeason.slice(1) %> <%= adjacentSeasons.prevYear %>
      </a>
      <span class="nav__current">
        <%= season.charAt(0).toUpperCase() + season.slice(1) %> <%= year %>
      </span>
      <a href="/season/<%= adjacentSeasons.nextYear %>/<%= adjacentSeasons.nextSeason %>">
        <%= adjacentSeasons.nextSeason.charAt(0).toUpperCase() + adjacentSeasons.nextSeason.slice(1) %> <%= adjacentSeasons.nextYear %> →
      </a>
    </div>
    <div class="nav__right">
      <div class="lang-toggle">
        <button data-lang="en" class="<%= user.langPref === 'en' ? 'active' : '' %>">EN</button>
        <button data-lang="jp" class="<%= user.langPref === 'jp' ? 'active' : '' %>">JP</button>
        <button data-lang="ru" class="<%= user.langPref === 'ru' ? 'active' : '' %>">RU</button>
      </div>
      <span class="nav__user"><%= user.username %></span>
      <a href="/logout">logout</a>
    </div>
  </nav>

  <main class="main">
    <div class="controls">
      <div class="controls__tabs">
        <button class="tab active" data-tab="all">All (<%= animeList.length %>)</button>
        <button class="tab" data-tab="following">Following (<%= [...userStatuses.values()].filter(s => s).length %>)</button>
      </div>
      <div class="controls__sort">
        <label>Sort by:</label>
        <select id="sort-select">
          <option value="score_mal">MAL Score</option>
          <option value="score_anilist">AniList Score</option>
          <option value="score_shiki">Shikimori Score</option>
          <option value="next_ep">Next Episode</option>
          <option value="title">Title</option>
        </select>
      </div>
    </div>

    <div class="card-grid">
      <% for (const anime of animeList) { %>
        <%- include('partials/card', { anime, userStatus: userStatuses.get(anime.mal_id), langPref: user.langPref }) %>
      <% } %>
    </div>
  </main>

  <!-- Detail Modal -->
  <div class="modal-backdrop" id="modalBackdrop">
    <div class="modal" id="animeModal" role="dialog" aria-modal="true">
      <div class="modal__header">
        <img class="modal__poster" id="modalPoster" src="" alt="">
        <div class="modal__info">
          <h2 class="modal__title" id="modalTitle"></h2>
          <div class="modal__titles">
            <span class="modal__title-jp" id="modalTitleJp"></span>
            <span class="modal__title-ru" id="modalTitleRu"></span>
          </div>
          <div class="modal__badges">
            <div class="modal__countdown" id="modalCountdown"></div>
            <span class="modal__status" id="modalStatus"></span>
            <span class="modal__episodes" id="modalEpisodes"></span>
          </div>
        </div>
        <button class="modal__close" id="modalClose" aria-label="Close">&times;</button>
      </div>
      <div class="modal__body">
        <div id="modalSynopsisEn" class="modal__synopsis modal__synopsis-en"></div>
        <div id="modalSynopsisRu" class="modal__synopsis modal__synopsis-ru"></div>
        <div id="modalGenres" class="modal__genres"></div>
        <div class="modal__scores" id="modalScores"></div>
        <div id="modalRelated" class="modal__related"></div>
      </div>
      <div class="modal__actions" id="modalActions">
        <button class="btn btn--follow" data-status="following">♡ Follow</button>
        <button class="btn btn--jellyfin" data-status="in_jellyfin">📦 Jellyfin</button>
        <button class="btn btn--watched" data-status="watched">✓ Watched</button>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
