<%
  const title = langPref === 'jp' ? (anime.title_jp || anime.title_en) :
                langPref === 'ru' ? (anime.title_ru || anime.title_en) :
                anime.title_en;
  const synopsisEn = anime.synopsis_en || '';
  const synopsisRu = anime.synopsis_ru || '';
  const synopsis = langPref === 'ru'
    ? (synopsisRu || synopsisEn)
    : (synopsisEn || synopsisRu);
  const synopsisShort = synopsis
    ? synopsis.substring(0, 120) + (synopsis.length > 120 ? '…' : '')
    : '';

  let countdownClass = '';
  if (anime.next_ep_at && anime.next_ep_at > Math.floor(Date.now() / 1000)) {
    countdownClass = '';
  } else if (anime.airing_status === 'Finished Airing') {
    countdownClass = 'countdown--released';
  } else if (anime.airing_status === 'Not yet aired') {
    countdownClass = 'countdown--not-aired';
  } else {
    countdownClass = 'countdown--tba';
  }

  const cardStatusClasses = [];
  if (userStatus === 'following') cardStatusClasses.push('card--following');
  if (userStatus === 'in_jellyfin') cardStatusClasses.push('card--jellyfin');
  if (userStatus === 'watched') cardStatusClasses.push('card--watched');
  const cardClass = cardStatusClasses.length > 0 ? cardStatusClasses.join(' ') : '';

  let countdownBadge = '';
  if (anime.next_ep_at && anime.next_ep_at > Math.floor(Date.now() / 1000)) {
    countdownBadge = '';
  } else if (anime.airing_status === 'Finished Airing') {
    countdownBadge = 'Released';
  } else if (anime.airing_status === 'Not yet aired') {
    countdownBadge = 'Not aired';
  } else {
    countdownBadge = 'TBA';
  }

  const genres = JSON.parse(anime.genres || '[]');

  const related = anime.related ? JSON.parse(anime.related) : [];
  const currentSeasonCard = typeof isCurrentSeason === 'undefined' ? true : Boolean(isCurrentSeason);
  const initiallyHiddenCard = typeof initiallyHidden === 'undefined' ? false : Boolean(initiallyHidden);

  const modalData = {
    mal_id: anime.mal_id,
    title_en: anime.title_en,
    title_jp: anime.title_jp,
    title_ru: anime.title_ru,
    synopsis_en: synopsisEn,
    synopsis_ru: synopsisRu,
    poster_url: anime.poster_url,
    score_mal: anime.score_mal,
    score_anilist: anime.score_anilist,
    score_shiki: anime.score_shiki,
    anilist_id: anime.anilist_id,
    episodes_total: anime.episodes_total,
    airing_status: anime.airing_status,
    airing_day: anime.airing_day,
    next_ep_num: anime.next_ep_num,
    next_ep_at: anime.next_ep_at,
    genres: genres,
    related: related
  };
%>

<div
  class="card <%= cardClass %> <%= initiallyHiddenCard ? 'card--hidden' : '' %>"
  data-mal-id="<%= anime.mal_id %>"
  data-followed="<%= userStatus ? 'true' : 'false' %>"
  data-in-current-season="<%= currentSeasonCard ? 'true' : 'false' %>"
  data-score-mal="<%= anime.score_mal || 0 %>"
  data-score-anilist="<%= anime.score_anilist || 0 %>"
  data-score-shiki="<%= anime.score_shiki || 0 %>"
  data-next-ep-at="<%= anime.next_ep_at || 0 %>"
  data-status="<%= userStatus || '' %>"
  data-modal="<%= Buffer.from(JSON.stringify(modalData)).toString('base64') %>"
>
  <img class="card__poster" src="<%= anime.poster_url %>" alt="<%= title %>" loading="lazy">
  <div class="card__body">
    <div class="card__header">
      <h3 class="card__title"><%= title %></h3>
    </div>
    <% if (langPref === 'en' && anime.title_jp) { %>
      <p class="card__subtitle"><%= anime.title_jp %></p>
    <% } else if (langPref === 'jp' && anime.title_en) { %>
      <p class="card__subtitle"><%= anime.title_en %></p>
    <% } else if (langPref === 'ru' && anime.title_en) { %>
      <p class="card__subtitle"><%= anime.title_en %></p>
    <% } %>
    <% if (anime.next_ep_at && anime.next_ep_at > Math.floor(Date.now() / 1000)) { %>
      <div class="card__countdown">
        <span class="countdown-timer" data-timestamp="<%= anime.next_ep_at %>">—</span>
        <span class="countdown-ep">ep <%= anime.next_ep_num %>/<%= anime.episodes_total || '?' %></span>
      </div>
    <% } else { %>
      <div class="card__countdown <%= countdownClass %>">
        <span><%= countdownBadge %></span>
      </div>
    <% } %>
    <div class="card__scores">
      <% if (anime.score_mal) { %>
        <a class="score score--mal" href="https://myanimelist.net/anime/<%= anime.mal_id %>" target="_blank" rel="noopener">MAL <%= anime.score_mal.toFixed(1) %></a>
      <% } %>
      <% if (anime.score_anilist && anime.anilist_id) { %>
        <a class="score score--al" href="https://anilist.co/anime/<%= anime.anilist_id %>" target="_blank" rel="noopener">AL <%= anime.score_anilist %></a>
      <% } %>
    </div>
    <p class="card__synopsis"><%= synopsisShort %></p>
    <button class="btn btn--more" data-moreless="more">Show more ▾</button>
    <div class="card__actions">
      <button class="btn btn--follow <%= userStatus === 'following' ? 'active' : '' %>" data-status="following">
        ♡ Follow
      </button>
      <button class="btn btn--jellyfin <%= userStatus === 'in_jellyfin' ? 'active' : '' %>" data-status="in_jellyfin">
        📦 Jellyfin
      </button>
      <button class="btn btn--watched <%= userStatus === 'watched' ? 'active' : '' %>" data-status="watched">
        ✓ Watched
      </button>
    </div>
  </div>
</div>
